GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
DEV_MODE=false
FORGE_PROJECT_ROOT=/home/user/Forge   # default: cwd
FORGE_ALLOWED_EXTENSIONS=.py,.js,.ts   # default: py,js,ts,go,rs,rb,java
FORGE_MAX_WRITE_BYTES=1048576          # default: 1MB
FORGE_SANDBOX=true                     # default: true
FORGE_EXEC_TIMEOUT=30                  # default: 30s
FORGE_EXTRA_COMMANDS=make,cargo    # comandos adicionales
FORGE_TERMINAL_MAX_LINES=200       # default: 200
FORGE_HTTP_TIMEOUT=15        # segundos por request
FORGE_MAX_CONTENT_CHARS=12000  # chars máximos de contenido al LLM
FORGE_CONTEXT_LIMIT=128000   # tokens del modelo — llama-3.3-70b tiene 128k
FORGE_COMPRESS_AT=0.80       # comprimir al 80% = 102,400 tokens